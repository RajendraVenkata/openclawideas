{
  // Sample config the bare loop reads (real path: ~/.openclaw/openclaw.json, JSON5).
  // Edit this while the gateway is running to watch step 3 hot-reload the snapshot.
  "gateway": {
    "port": 18789,
    "bind": "loopback",
    "auth": {
      // mode defaults to "token" when only a token is set (see auth-resolve.ts).
      // If you set BOTH token and password without "mode", startup fails (step 2 guard).
      "token": "dev-secret-token"
    },
    "reload": {
      "mode": "hybrid",
      "debounceMs": 300
    }
  },
  "channels": {
    "whatsapp": {
      "enabled": true,
      "accountId": "default",
      "dmPolicy": "open"
    },
    "msteams": {
      "enabled": true,
      "accountId": "default",
      "appId": "00000000-0000-0000-0000-000000000000",
      "tenantId": "contoso.onmicrosoft.com",
      "dmPolicy": "open"
    },
    "webhook": {
      "enabled": true,
      "accountId": "default",
      // Inbound security (real openclaw model): pairing → unknown senders get a
      // code and aren't processed until an operator approves. "alice" is allowlisted.
      "dmPolicy": "pairing",
      "allowFrom": ["alice"],
      "inbound": { "port": 4000, "path": "/webhook/inbound", "secret": "dev-secret" },
      "outbound": { "url": "http://127.0.0.1:4001/receive" }
    },
    "cli": {
      // CLI clients connect over the gateway WebSocket (:18789). Each connection
      // is a peer; pairing codes are shown ONLY on this console (not over chat).
      "enabled": true,
      "dmPolicy": "pairing",
      "pairingCodeDelivery": "console"
    }
  }
}
