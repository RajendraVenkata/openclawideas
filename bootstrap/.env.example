# Copy to .env (NOT checked in) and fill in.

# === Required ===
# The token you started the container with.
# Example: docker run ... -e OPENCLAW_GATEWAY_TOKEN=$(openssl rand -hex 32) ...
OPENCLAW_GATEWAY_TOKEN=

# Where to reach the Gateway. Defaults to ws://127.0.0.1:18789.
OPENCLAW_GATEWAY_URL=ws://127.0.0.1:18789


# === Model provider (pick at least one) ===

# OpenAI API key. If set, bootstrap configures OpenAI as a provider.
OPENAI_API_KEY=

# OpenAI base URL. Defaults to https://api.openai.com/v1.
# Set this for Azure OpenAI, vLLM, or a proxy. The current Gateway version
# requires baseUrl to be a non-empty string when an openai provider entry
# exists, so bootstrap always includes a value (either this env or the
# default).
OPENAI_BASE_URL=

# Anthropic API key. If set, bootstrap configures Anthropic as a provider.
# Both can be set at the same time.
ANTHROPIC_API_KEY=

# Anthropic base URL. Defaults to https://api.anthropic.com.
ANTHROPIC_BASE_URL=

# Default model. Format is "<provider>/<model-id>".
# If unset, bootstrap picks based on which provider key is present:
#   - OPENAI_API_KEY set     -> openai/gpt-5.5
#   - ANTHROPIC_API_KEY set  -> anthropic/claude-sonnet-4-6
# Override here if you want a specific model:
#   openai/gpt-5.5
#   openai/gpt-4o-mini
#   anthropic/claude-sonnet-4-6
#   anthropic/claude-opus-4-6
OPENCLAW_DEFAULT_MODEL=


# === Optional: Telegram channel ===
# Bot token from @BotFather.
TELEGRAM_BOT_TOKEN=

# Your numeric Telegram user id (e.g. 8734062810).
# Find via: openclaw logs --follow on the host (DM the bot, read `from.id`).
TELEGRAM_USER_ID=
